# ============================================================
# BACKEND — configure no Render como Environment Variables
# ============================================================

# Telegram Bot (obrigatório para alertas)
# Gere em https://t.me/BotFather
TELEGRAM_BOT_TOKEN=seu_token_aqui

# ID do chat/grupo onde os alertas serão enviados
# Obtenha via @userinfobot no Telegram
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Desabilite o Telegram durante testes
TELEGRAM_ENABLED=true

# PostgreSQL — no Render é injetado automaticamente via fromDatabase
DATABASE_URL=postgresql://user:password@host:5432/dbname

# URL do frontend (usada para CORS)
# No Render: https://hyperliquid-frontend.onrender.com
FRONTEND_URL=http://localhost:3000

# ============================================================
# FRONTEND — configure no Render como Environment Variables
# ============================================================

# URL do backend
# No Render: https://hyperliquid-backend.onrender.com
REACT_APP_API_URL=http://localhost:8000
